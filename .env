NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/velozity?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Internal API Key for /health and /metrics
INTERNAL_API_KEY=internal-secret-key-change-in-production

# Email (Ethereal test credentials - will be auto-generated if empty)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Rate Limiting Defaults
RATE_LIMIT_GLOBAL=1000
RATE_LIMIT_BURST=50
RATE_LIMIT_BURST_WINDOW=5

# API Key rotation grace period in minutes
API_KEY_ROTATION_GRACE_MINUTES=15